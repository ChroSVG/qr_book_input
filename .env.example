# ============================================
# Environment: Development (Default)
# ============================================
# Usage: docker compose up -d --build
# ============================================

# Backend
DB_ECHO=true
CORS_ORIGINS=["*"]
API_KEY=

# Frontend
VITE_API_BASE=http://localhost:8001
VITE_API_KEY=
VITE_PDF_API_BASE=

# Health Check (Development)
HEALTH_INTERVAL=10s
HEALTH_TIMEOUT=5s
HEALTH_RETRIES=3
HEALTH_START_PERIOD=10s

# Resource Limits (Development - Unlimited)
CPU_LIMIT=4
MEMORY_LIMIT=2G
CPU_RESERVATION=0.5
MEMORY_RESERVATION=256M

# Frontend Resource Limits
FRONTEND_CPU_LIMIT=2
FRONTEND_MEMORY_LIMIT=1G
FRONTEND_CPU_RESERVATION=0.25
FRONTEND_MEMORY_RESERVATION=128M
