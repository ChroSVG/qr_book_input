# Backend URL untuk Vite proxy
# Untuk akses lokal
VITE_BACKEND_URL=http://localhost:8001

# Untuk akses dari komputer lain via Cloudflare Tunnel,
# ganti dengan URL tunnel Anda, contoh:
# VITE_BACKEND_URL=http://192.168.1.100:8001
# atau
# VITE_BACKEND_URL=https://your-tunnel-domain.trycloudflare.com

# Third-party PDF API base URL
# Kosongkan jika PDF API ada di domain yang sama
VITE_PDF_API_BASE=
