# Backend configuration for Cloudflare Tunnel access

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///data/data.db

# CORS Configuration
# Untuk development, bisa gunakan wildcard:
CORS_ORIGINS=["*"]

# Untuk production, spesifikkan domain:
# CORS_ORIGINS=["https://your-domain.com", "https://your-tunnel.trycloudflare.com"]

# Authentication
API_KEY=your-api-key-here
JWT_SECRET=your-jwt-secret-here-generate-with-python-secrets-token-urlsafe-64

# SSL (optional, jika tidak menggunakan Cloudflare Tunnel)
# SSL_KEYFILE=/path/to/key.pem
# SSL_CERTFILE=/path/to/cert.pem

