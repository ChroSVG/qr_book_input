# Backend configuration for input.arraayah.my.id
# Copy this to backend/.env

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///data/data.db
DB_ECHO=false

# CORS - IMPORTANT: Ganti dengan domain Anda
CORS_ORIGINS=["https://input.arraayah.my.id"]

# API Key Authentication (generate your own)
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here

# SSL (not needed when using Nginx Proxy Manager)
# SSL_KEYFILE=
# SSL_CERTFILE=

# Frontend dist path
DIST_DIR=dist
